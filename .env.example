# PostgreSQL — required (schema uses postgresql)
#
# Local dev (easiest): start Docker Postgres, then db push + seed
#   docker compose up -d
#   DATABASE_URL="postgresql://bmmapp:bmmapp@localhost:5432/bmmapp"
#
# Local dev (no Docker): free Neon DB at https://neon.tech — paste connection string below
# Production (Vercel): use your Neon/Supabase URL with ?sslmode=require
DATABASE_URL="postgresql://bmmapp:bmmapp@localhost:5432/bmmapp"

# Auth — generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://rsvpshare.com"
NEXT_PUBLIC_SITE_URL="https://rsvpshare.com"

# Admin account (used by npm run db:seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# Vercel Blob — required for logo uploads in production
# Create at: Vercel project → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=""
# Use "public" only if your Blob store was created with public access (default: private)
BLOB_ACCESS_MODE="private"
